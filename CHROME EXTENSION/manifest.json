{
  "manifest_version": 3,
  "name": "Freeze Detector",
  "version": "1.1",
  "description": "Monitors activity and notifies when inactivity is detected.",
  "permissions": ["tabs"],
  "host_permissions": ["http://192.168.1.120:25565/*"],
  "background": {"service_worker": "background.js"},
  "action": {"default_title": "Freeze Detector"},
  "icons": {"128": "icon.png"},
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
